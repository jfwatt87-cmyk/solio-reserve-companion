{
  "name": "solio-reserve-poc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Proof-of-concept companion app for Solio Game Reserve \u2014 georeferenced reserve map, live self-location, on-reserve navigation, self-guided drives and sightings. No rhino tracking by design.",
  "scripts": {
    "dev": "vite",
    "prebuild": "node tools/gen-tile-manifest.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:prod": "bash tools/deploy-prod.sh"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
